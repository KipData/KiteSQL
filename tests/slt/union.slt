query I rowsort
select 1 union select 2
----
1
2

query I rowsort
select 1 union select 2 + 1
----
1
3

query I rowsort
select 1 union select 1
----
1

query I rowsort
select 1 union all select 1
----
1
1

query T rowsort
select (1, 2) union select (2, 1) union select (1, 2)
----
(1, 2)
(2, 1)

