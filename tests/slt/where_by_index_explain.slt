statement ok
create table t_cover(id int primary key, c1 int, c2 int, c3 int);

statement ok
insert into t_cover values
    (1, 1, 10, 11),
    (2, 2, 20, 21),
    (3, 2, 22, 23),
    (4, 3, 30, 31);

statement ok
create index idx_cover on t_cover (c1, c2, c3);

# composite index trailing columns cover (index columns > output columns)
query T
explain select c2, c3 from t_cover where c1 = 2;
----
Columns: #24=t_cover.c1, #25=t_cover.c2, #26=t_cover.c3 Projection [#25, #26] [Project => (Sort Option: Follow)] Filter (#24 = 2), Is Having: false [Filter => (Sort Option: Follow)] TableScan t_cover -> [#24, #25, #26] [SeqScan => (Sort Option: None)]

statement ok
