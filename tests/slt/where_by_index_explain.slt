statement ok
analyze table t1;

query T
explain select * from t1 limit 10;
----
Projection [t1.id, t1.c1, t1.c2] [Project => (Sort Option: Follow)] TableScan t1 -> [id, c1, c2], Limit: 10 [SeqScan => (Sort Option: None)]

query T
explain select * from t1 where id = 0;
