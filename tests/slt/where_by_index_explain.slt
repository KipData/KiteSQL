statement ok
analyze table t1;

query T
explain select * from t1 limit 10;
----
Projection [#1, #2, #3] [Project => (Sort Option: Follow)] TableScan t1 -> [#1, #2, #3], Limit: 10 [SeqScan => (Sort Option: None)]

query T
explain select * from t1 where id = 0;
----
Projection [#1, #2, #3] [Project => (Sort Option: Follow)] Filter (#1 = 0), Is Having: false [Filter => (Sort Option: Follow)] TableScan t1 -> [#1, #2, #3] [IndexScan By #0 => 0 => (Sort Option: OrderBy: (#1 Asc Nulls Last) ignore_prefix_len: 0)]

