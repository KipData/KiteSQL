Projection [t1.c2, t1.c1] [Project => (Sort Option: Follow)] Filter ((((t1.c1 < 10) && (t1.c1 > 0)) && (t1.c2 > 0)) && (t1.c2 < 10)), Is Having: false [Filter => (Sort Option: Follow)] TableScan t1 -> [c1, c2] [IndexScan By p_index => ((0), (10)) Covered => (Sort Option: OrderBy: (t1.c1 Asc Nulls Last, t1.c2 Asc Nulls Last) ignore_prefix_len: 0)]


statement ok
drop table t1;

statement ok
create table t_cover(id int primary key, c1 int, c2 int, c3 int);

statement ok
insert into t_cover values
    (1, 1, 10, 11),
    (2, 2, 20, 21),
    (3, 2, 22, 23),
    (4, 3, 30, 31);

statement ok
create index idx_cover on t_cover (c1, c2, c3);

# composite index trailing columns cover (index columns > output columns)
query T
explain select c2, c3 from t_cover where c1 = 2;
----
Projection [t_cover.c2, t_cover.c3] [Project => (Sort Option: Follow)] Filter (t_cover.c1 = 2), Is Having: false [Filter => (Sort Option: Follow)] TableScan t_cover -> [c1, c2, c3] [SeqScan => (Sort Option: None)]

statement ok
drop table t_cover;
