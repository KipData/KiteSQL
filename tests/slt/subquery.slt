statement ok
insert into scalar_outer_err values (1);

statement ok
insert into scalar_inner_err values (1), (2);

statement error
select * from scalar_outer_err where id = (select v from scalar_inner_err);

statement ok
drop table scalar_outer_err;

statement ok
drop table scalar_inner_err;

